# Copie para .env (make studio faz isso automaticamente).

# --- Agentes / Ollama ---
POTO_AGENTS_ENABLED=true
POTO_OLLAMA_URL=http://localhost:11434
POTO_OLLAMA_MODEL=llama3.2:3b

# --- Speech-to-Text ---
# none | faster-whisper  (instale com `make stt-setup`)
POTO_STT_PROVIDER=faster-whisper
POTO_WHISPER_MODEL=base

# --- Notificação externa ---
# Redireciona TODOS os destinos para um número durante testes em bancada.
POTO_CONTACT_OVERRIDE=5586981804692
# log | webhook | telegram | twilio
POTO_NOTIF_PROVIDER=twilio
POTO_NOTIF_WEBHOOK_URL=
POTO_NOTIF_WEBHOOK_TOKEN=
POTO_TELEGRAM_BOT_TOKEN=
POTO_TELEGRAM_CHAT_ID=
POTO_SLA_CHECK_INTERVAL=30

# Pânico (§13.2): canais internos acionados no broadcast (lista por vírgula).
# Padrão = autoridades alcançáveis por voz; ex.: csv,sala_lilas,sapsi,ouvidoria
POTO_PANICO_CANAIS=csv,sala_lilas

# Twilio — voz (Calls) ou sms (Messages). Nunca commite credenciais reais.
POTO_TWILIO_ACCOUNT_SID=
POTO_TWILIO_AUTH_TOKEN=
POTO_TWILIO_FROM=
POTO_TWILIO_MODE=voice
# Voz pt-BR da locução do alerta (TwiML <Say>). "Polly.Camila-Neural" se a conta tiver.
POTO_TWILIO_VOICE=Polly.Camila
# URL pública do backend (túnel cloudflared/ngrok) p/ o statusCallback do Twilio.
# Vazio = a ligação sai, mas sem status ao vivo (tocando/atendida) nas telas.
POTO_PUBLIC_BASE_URL=

# Contatos por canal (usados quando POTO_CONTACT_OVERRIDE estiver vazio)
POTO_CONTACT_CSV=558632155591
POTO_CONTACT_SALA_LILAS=5586994287263
POTO_CONTACT_SAPSI=sapsi@ufpi.edu.br
POTO_CONTACT_OUVIDORIA=ouvidoria@ufpi.br
POTO_CONTACT_SAMU=192
POTO_CONTACT_PM=190
POTO_CONTACT_BOMBEIROS=193
POTO_CONTACT_180=180

# --- LangSmith (opcional: tracing do fluxo no LangSmith) ---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=poto-triagem
