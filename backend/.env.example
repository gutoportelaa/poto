# Copie para .env (make studio faz isso automaticamente).

# --- Agentes / Ollama ---
POTO_AGENTS_ENABLED=true
POTO_OLLAMA_URL=http://localhost:11434
POTO_OLLAMA_MODEL=llama3.2:3b

# --- Speech-to-Text ---
# none | faster-whisper  (instale com `make stt-setup`)
POTO_STT_PROVIDER=faster-whisper
POTO_WHISPER_MODEL=base

# --- Notificação externa ---
# Redireciona TODOS os destinos para um número durante testes em bancada.
POTO_CONTACT_OVERRIDE=5586981804692
# log | webhook | telegram | twilio | simcom
POTO_NOTIF_PROVIDER=twilio
POTO_NOTIF_WEBHOOK_URL=
POTO_NOTIF_WEBHOOK_TOKEN=
POTO_TELEGRAM_BOT_TOKEN=
POTO_TELEGRAM_CHAT_ID=
POTO_SLA_CHECK_INTERVAL=30

# Pânico (§13.2): canais internos acionados no broadcast (lista por vírgula).
# Padrão = autoridades alcançáveis por voz; ex.: csv,sala_lilas,sapsi,ouvidoria
POTO_PANICO_CANAIS=csv,sala_lilas

# Twilio — voz (Calls) ou sms (Messages). Nunca commite credenciais reais.
POTO_TWILIO_ACCOUNT_SID=
POTO_TWILIO_AUTH_TOKEN=
POTO_TWILIO_FROM=
POTO_TWILIO_MODE=voice
# Voz pt-BR da locução do alerta (TwiML <Say>). "Polly.Camila-Neural" se a conta tiver.
POTO_TWILIO_VOICE=Polly.Camila
# Alerta PSTN (ligação ao celular do contato). Em demos de chamada ao vivo,
# use "off" para não gastar crédito do trial a cada ocorrência. A chamada A/V ao
# vivo (WebRTC P2P nativo, totem↔central) não é afetada. on (padrão) | off
POTO_ALERTA_PSTN=on

# Chamada A/V ao vivo totem↔central = WebRTC P2P nativo (sem Twilio). TURN só é
# necessário atrás de NAT simétrico: POTO_TURN_URL/POTO_TURN_USER/POTO_TURN_PASS.

# URL pública do backend (túnel cloudflared/ngrok) p/ o statusCallback do Twilio.
# Vazio = a ligação sai, mas sem status ao vivo (tocando/atendida) nas telas.
POTO_PUBLIC_BASE_URL=

# --- Locução de voz: como o áudio da ligação é gerado ---
# say   = TwiML <Say> (Polly/básica acima) | local = TTS offline (Piper) via <Play>
# 'local' tem custo de TTS ZERO no Twilio (só toca o WAV) e exige POTO_PUBLIC_BASE_URL.
POTO_VOICE_TTS=say
POTO_PIPER_BIN=piper
# Caminho do modelo .onnx do Piper (ex.: ~/piper/pt_BR-faber-medium.onnx)
POTO_PIPER_MODEL=
# POTO_AUDIO_DIR=  (padrão: backend/audio_cache)
# POTO_AUDIO_TTL_SEG=900

# --- SIMCom A7670SA: canal GSM/2G real (POTO_NOTIF_PROVIDER=simcom) ---
# SIM real → o totem disca de número próprio, sem número virtual. Ver docs/hardware-simcom.md.
# Instale a dep na rasp:  uv sync --extra simcom
# Porta AT do módulo (o A7670SA USB enumera vários ttyUSB*; costuma ser a 2 ou 3).
POTO_SIMCOM_PORT=/dev/ttyUSB2
POTO_SIMCOM_BAUD=115200
# voice = só liga | sms = só SMS | both = liga E manda SMS com o protocolo (recomendado).
POTO_SIMCOM_MODE=both
# Segundos mantendo a ligação no ar (toca / toca a locução) antes de desligar.
POTO_SIMCOM_CALL_SEG=20
# Força 2G-only (AT+CNMP=13) p/ voz — A7670SA não tem VoLTE, voz só via CSFB/2G.
POTO_SIMCOM_FORCE_GSM=true
# Toca a locução pt-BR (WAV do Piper) DENTRO da ligação. Template com {wav}. Exige
# POTO_VOICE_TTS=local + POTO_PIPER_MODEL. Vazio = ligação só toca (ring), sem fala.
# Ex.: POTO_SIMCOM_AUDIO_CMD=aplay -D plughw:CARD=Module,DEV=0 {wav}
POTO_SIMCOM_AUDIO_CMD=
# Dispositivo de voz do módulo (AT+CSDVC): 1=handset, 3=viva-voz. Vazio = não mexe.
POTO_SIMCOM_SPK_DEVICE=

# Contatos por canal (usados quando POTO_CONTACT_OVERRIDE estiver vazio)
POTO_CONTACT_CSV=558632155591
POTO_CONTACT_SALA_LILAS=5586994287263
POTO_CONTACT_SAPSI=sapsi@ufpi.edu.br
POTO_CONTACT_OUVIDORIA=ouvidoria@ufpi.br
POTO_CONTACT_SAMU=192
POTO_CONTACT_PM=190
POTO_CONTACT_BOMBEIROS=193
POTO_CONTACT_180=180

# --- LangSmith (opcional: tracing do fluxo no LangSmith) ---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=poto-triagem
